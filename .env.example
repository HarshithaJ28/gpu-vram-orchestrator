# ============================================================================
# GPU VRAM ORCHESTRATOR - ENVIRONMENT CONFIGURATION
# ============================================================================

# API Configuration
DEBUG=false
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# GPU Configuration
GPU_ENABLED=true
NUM_GPUS=2
GPU_MEMORY_MB=24000
RESERVE_MEMORY_MB=2000

# Model Registry
MODELS_DIR=./models
MODEL_STORAGE_PATH=./models

# Preloader Configuration
PRELOAD_INTERVAL_SECONDS=60
PRELOAD_CONFIDENCE_THRESHOLD=0.5
PRELOAD_MAX_PER_CYCLE=3
PRELOAD_ENABLED=true

# ML Predictor
PREDICTOR_HISTORY_WINDOW_HOURS=24
PREDICTOR_MIN_OBSERVATIONS=5

# Security - API Keys
API_KEY=your-secret-api-key-here-change-in-production
API_KEYS_ENABLED=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=10000

# Monitoring
PROMETHEUS_ENABLED=true
METRICS_PORT=8001
METRICS_INTERVAL_SECONDS=10

# Redis (optional - for distributed rate limiting)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# Load Testing
LOAD_TEST_ENABLED=false
LOAD_TEST_CONCURRENT_USERS=10
LOAD_TEST_REQUESTS_PER_USER=100

# Testing
TEST_MODE=false
TESTING=false

# Logging
LOG_FORMAT=json|text
LOG_TO_FILE=false
LOG_FILE=./logs/orchestrator.log

# Model Cache
CACHE_ENABLED=true
CACHE_MIN_FREE_MEMORY_MB=500
CACHE_EVICTION_POLICY=lru

# Inference
INFERENCE_TIMEOUT_SECONDS=300
INFERENCE_BATCH_SIZE=32
INFERENCE_MAX_BATCH_SIZE=256

# Performance
ENABLE_ASYNC_PRELOAD=true
ENABLE_BACKGROUND_METRICS=true
METRICS_UPDATE_INTERVAL_SECONDS=10
